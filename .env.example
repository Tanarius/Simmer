# API Keys for AI Integrations
ANTHROPIC_API_KEY=          # from console.anthropic.com
SPOONACULAR_API_KEY=        # from spoonacular.com/food-api (free tier)
EDAMAM_APP_ID=              # from developer.edamam.com (Recipe Search API — PAID plan required, ~$29/mo)
EDAMAM_APP_KEY=             # leave blank to skip Edamam and use Spoonacular + TheMealDB only
UNSPLASH_ACCESS_KEY=        # from unsplash.com/developers (free tier, 50 req/hr)

# Database Configuration (Neon)
DATABASE_URL=               # Neon PostgreSQL connection string (already set)

# Optional: Tasty API via RapidAPI (500 free calls/month — adds recipe variety)
RAPIDAPI_KEY=               # from rapidapi.com/Tasty API subscription

# Session
SESSION_SECRET=             # Random securely generated string
